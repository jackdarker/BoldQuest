        <mxCell id="8dLabJqgLiKEnNsHqGqc-1" value="&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;NPC picks player as Talk-Target (if allowed)&lt;/p&gt;&lt;p&gt;- Player-Task gets interupted&lt;/p&gt;&lt;p&gt;- show Talk-scene&lt;/p&gt;&lt;p&gt;on done:&lt;/p&gt;&lt;p&gt;- set NPC-Task done&lt;/p&gt;&lt;p&gt;- return and continue interupted scene&lt;/p&gt;&lt;p&gt;or return and flush player-task&lt;/p&gt;&lt;p&gt;or flush player-task &amp;amp; start another scene (combat)&lt;/p&gt;" style="text;html=1;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;expand=1;collapsible=1;" vertex="1" parent="1">
