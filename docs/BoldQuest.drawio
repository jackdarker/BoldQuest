        <mxCell id="NosLP425g_tXGi0YMW1F-15" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;NPC around and interested?&lt;/p&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;calculate NPC-attitude:&lt;/p&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;despaired&amp;nbsp; -&amp;gt; ask for help&lt;/p&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;helpful -&amp;gt; respond politely&lt;/p&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;neutral -&amp;gt; respond politely&lt;/p&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;wicked/trickster -&amp;gt; false offer&lt;/p&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;horny -&amp;gt; ask for sex/ attack&lt;/p&gt;&lt;p style=&quot;line-height: 12px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;unfriendly -&amp;gt; speak offensive/attack&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;flavour depending on dominant/history&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;spacing=5;spacingTop=-20;overflow=hidden;rounded=0;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;expand=1;collapsible=1;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1359.5" y="620" width="200" height="300" as="geometry">
            <mxRectangle x="695" y="-500" width="30" height="30" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="NosLP425g_tXGi0YMW1F-16" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;&lt;br&gt;&lt;/p&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;scene delay:&lt;/p&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;after a scene is done, the player is left alone for a while unless NPC are very interested&lt;/p&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;NPC-priority: the most interested NPC gets the scene&lt;/p&gt;&lt;p style=&quot;line-height: 100%;&quot;&gt;= bored + attitude&lt;/p&gt;&lt;p&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;spacing=5;spacingTop=-20;overflow=hidden;rounded=0;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;expand=1;collapsible=1;whiteSpace=wrap;" parent="1" vertex="1">
